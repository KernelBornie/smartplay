# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/smartplay

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# File uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=52428800

# Service ports (internal)
AUTH_SERVICE_PORT=3001
MUSIC_SERVICE_PORT=3002
STREAMING_SERVICE_PORT=3003
ANALYTICS_SERVICE_PORT=3004
ADMIN_SERVICE_PORT=3005

# Service URLs (for API gateway routing)
AUTH_SERVICE_URL=http://localhost:3001
MUSIC_SERVICE_URL=http://localhost:3002
STREAMING_SERVICE_URL=http://localhost:3003
ANALYTICS_SERVICE_URL=http://localhost:3004

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
